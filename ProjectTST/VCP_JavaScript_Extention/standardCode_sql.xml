FUNCTION zcxt_lagging_text.
*"----------------------------------------------------------------------
*"*"Local Interface:
*"  IMPORTING
*"     VALUE(GLOBALS) TYPE  CUOV_00
*"  TABLES
*"      QUERY STRUCTURE  CUOV_01
*"      MATCH STRUCTURE  CUOV_01
*"  EXCEPTIONS
*"      FAIL
*"      INTERNAL_ERROR
*"----------------------------------------------------------------------
  DATA : lagging_text   LIKE cuov_01-atwrt,    "FOR THE RESULT OF THE CONCATENATE OF TEXT
         value1         LIKE cuov_01-atwrt,    "FOR THE CHARACTERISTIC CXT_THICKNESS
         value1_num     LIKE cuov_01-atflv,    "Numeric value of CXT_THICKNESS
         value2         LIKE cuov_01-atwrt,    "FOR THE CHARACTERISTIC CXT_WIDTH
         value2_num     LIKE cuov_01-atflv,    "Numeric value of CXT_WIDTH
         value3         LIKE cuov_01-atwrt,    "FOR THE CHARACTERISTIC CXT_LENGTH
         value3_num     LIKE cuov_01-atflv,    "Numeric value of CXT_LENGTH
         valuex_num     LIKE cuov_01-atflv,    "FOR THE NUMERIC CHARACTERISTIC
         valuex_int(3)  TYPE n,
         lagging_text30 LIKE cuov_01-atwrt.

  DATA: value1_p1(16) TYPE p DECIMALS 2,
        value2_p1(16) TYPE p DECIMALS 2,
        value3_p1(16) TYPE p DECIMALS 2,
        value1_c(6)   TYPE c,
        value2_c(6)   TYPE c,
        value3_c(6)   TYPE c.


* Get the Lagging Thickness
  CALL FUNCTION 'CUOV_GET_FUNCTION_ARGUMENT'
    EXPORTING
      argument      = 'CXT_THICKNESS'
    IMPORTING
*     SYM_VAL       = VALUE1
      num_val       = value1_num
    TABLES
      query         = query
    EXCEPTIONS
      arg_not_found = 1
      OTHERS        = 2.
  IF sy-subrc <> 0.
*   MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*           WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.

* Apply proper Thickness in Inches
  CASE value1_num.
    WHEN '0.58'.
      value1_p1 = 7.
    WHEN '0.67'.
      value1_p1 = 8.
    WHEN '0.83'.
      value1_p1 = 10.
    WHEN OTHERS.
      value1_p1 = value1_num * 12.
  ENDCASE.


*  value1_p1 = value1_num * 12.

  WRITE value1_p1 TO value1_c LEFT-JUSTIFIED.
  IF value1_c+4(2) = '00'.
    value1_c = value1_c+0(3).
  ELSEIF value1_c+4(1) = '0'.
    value1_c = value1_c+0(4).
  ENDIF.

* Get the Lagging Width
  CALL FUNCTION 'CUOV_GET_FUNCTION_ARGUMENT'
    EXPORTING
      argument      = 'CXT_WIDTH'
    IMPORTING
*     SYM_VAL       = VALUE1
      num_val       = value2_num
    TABLES
      query         = query
    EXCEPTIONS
      arg_not_found = 1
      OTHERS        = 2.
  IF sy-subrc <> 0.
*   MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*           WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.

  value2_p1 = value2_num * 12.

  WRITE value2_p1 TO value2_c LEFT-JUSTIFIED.
  IF value2_c+4(2) = '00'.
    value2_c = value2_c+0(3).
  ELSEIF value2_c+4(1) = '0'.
    value2_c = value2_c+0(4).
  ENDIF.

* Get the Lagging Length
  CALL FUNCTION 'CUOV_GET_FUNCTION_ARGUMENT'
    EXPORTING
      argument      = 'CXT_LENGTH'
    IMPORTING
*     SYM_VAL       = VALUE1
      num_val       = value3_num
    TABLES
      query         = query
    EXCEPTIONS
      arg_not_found = 1
      OTHERS        = 2.
  IF sy-subrc <> 0.
*   MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*           WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.

  value3_p1 = value3_num * 12.

  WRITE value3_p1 TO value3_c LEFT-JUSTIFIED.
  IF value3_c+4(2) = '00'.
    value3_c = value3_c+0(3).
  ELSEIF value3_c+5(1) = '0'.
    value3_c = value3_c+1(4).
  ENDIF.

*Concatenate the string
  CONCATENATE value1_c 'in' 'X' value2_c 'in' 'X' value3_c 'in' INTO lagging_text SEPARATED BY space.

  REFRESH match.
  CALL FUNCTION 'CUOV_SET_FUNCTION_ARGUMENT'
    EXPORTING
      argument = 'CXT_CUSTOM_TEXT'
      vtype    = 'CHAR'
      sym_val  = lagging_text
*     NUM_VAL  =
    TABLES
      match    = match
* EXCEPTIONS
*     EXISTING_VALUE_REPLACED       = 1
*     OTHERS   = 2
    .
  IF sy-subrc <> 0.
* MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*         WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.





ENDFUNCTION.


